# ===========================
# ACCOUNT 1: joshua.meyer@cs.uni-saarland.de
# ===========================

# 1. The Remote Account (IMAP)
IMAPAccount cs
Host imap.cs.uni-saarland.de
User joshua.meyer
Port 993
# Ideally use 'PassCmd "gpg ..."' but for setup, paste the raw password below.
# If using Gmail/Outlook with 2FA, you MUST use an 'App Password' here.
PassCmd "security find-generic-password -a 'joshua.meyer@cs.uni-saarland.de' -s 'mbsync' -w"
TLSType IMAPS
AuthMechs LOGIN

# 2. The Remote Connection
IMAPStore cs-remote
Account cs

# 3. The Local Storage (Maildir)
MaildirStore cs-local
Path ~/mail/cs/
# The trailing slash is important!
Inbox ~/mail/cs/inbox
SubFolders Verbatim

# 4. The Channel (Syncs Remote <-> Local)
Channel cs-inbox
Far :cs-remote:
Near :cs-local:
# Synchronize All folders
Patterns *
# Sync state files location
Create Both
Expunge Both
SyncState *

