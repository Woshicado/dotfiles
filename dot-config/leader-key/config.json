    {
      "actions": [
        {
          "key": "h",
          "type": "command",
          "value": "/opt/homebrew/bin/yabai -m query --windows | /opt/homebrew/bin/jq -r '.[] | select(.\"is-floating\" == true) | .app' | xargs -I{} /usr/bin/osascript -e \"tell application \\\"System Events\\\" to set visible of process \\\"{}\\\" to false\""
        },
        {
          "key": "y",
          "type": "command",
          "value": "/opt/homebrew/bin/yabai -m space --layout \"$(/opt/homebrew/bin/yabai -m query --spaces --space | /opt/homebrew/bin/jq -r 'if .type == \"bsp\" then \"stack\" else \"bsp\" end')\""
        },
        {
          "key": "b",
          "type": "command",
          "value": "/opt/homebrew/bin/yabai -m space --balance"
        },
        {
          "key": "m",
          "type": "command",
          "value": "/opt/homebrew/bin/yabai -m window --toggle zoom-fullscreen"
        },
        {
          "key": "r",
          "type": "command",
          "value": "/opt/homebrew/bin/yabai -m space --rotate 270"
        },
        {
          "key": "w",
          "type": "command",
          "value": "/opt/homebrew/bin/yabai -m window --close"
        },
        {
          "key": "R",
          "type": "command",
          "value": "killall yabai"
        }
      ],
