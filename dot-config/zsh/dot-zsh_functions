#!/usr/bin/env bash

jview() {
  local -a filter_keys
  local -a display_keys
  local file=""

  # 1. Parse Arguments
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -f)
        if [[ -n "$2" ]]; then
          filter_keys+=("$2")
          shift 2
        else
          echo "Error: -f requires a key argument." >&2
          return 1
        fi
        ;;
      *)
        if [[ -z "$file" ]]; then
          file="$1"
        else
          display_keys+=("$1")
        fi
        shift
        ;;
    esac
  done

  # 2. Validation
  if [[ -z "$file" ]]; then
    echo "Usage: jview [-f filter_key]... filename [display_key]..." >&2
    return 1
  fi

  if [[ ! -f "$file" ]]; then
    echo "Error: File '$file' not found." >&2
    return 1
  fi

  if [[ ${#display_keys[@]} -eq 0 ]]; then
    echo "Error: You must provide at least one key to display." >&2
    return 1
  fi

  # 3. Default Filter Logic
  if [[ ${#filter_keys[@]} -eq 0 ]]; then
    # Zsh vs Bash array indexing check
    if [ -n "$BASH_VERSION" ]; then
       filter_keys=("${display_keys[0]}")
    else
       filter_keys=("${display_keys[1]}")
    fi
  fi

  # --- HELPER: Format key for jq ---
  # Transforms "a.b" -> ."a"."b"
  # Transforms "a/b" -> ."a/b"
  # This treats '.' as a nested separator, but keeps everything else (like /) literal.
  get_jq_path() {
    local input="$1"
    # Escape existing double quotes in the key first
    local escaped="${input//\"/\\\"}"
    # Replace dots with quote-dot-quote:  .  ->  "."
    local dotted="${escaped//./\".\"}"
    # Wrap entire string in starting/ending quotes and prepend dot
    echo ".\"$dotted\""
  }

  # 4. Build jq 'select' string
  local select_cond=""
  for key in "${filter_keys[@]}"; do
    if [[ -n "$select_cond" ]]; then
      select_cond+=" and "
    fi
    local jq_path=$(get_jq_path "$key")
    select_cond+="$jq_path != null"
  done

  # 5. Build jq projection string
  local project_cond=""
  for key in "${display_keys[@]}"; do
    local jq_path=$(get_jq_path "$key")
    project_cond+="\"$key\": $jq_path, "
  done
  project_cond="${project_cond%, }" # Remove trailing comma

  # 6. Execute
  jq "select($select_cond) | { $project_cond }" "$file" | jless
}

# --- AUTOCOMPLETION (unchanged from previous valid version) ---
_jview() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -C \
    '*-f[Filter by key]:json_key:->keys' \
    '1:json_file:_files' \
    '*:json_key:->keys'

  case "$state" in
    keys)
      local json_file=""
      for w in "${words[@]}"; do
        if [[ -f "$w" ]]; then
          json_file="$w"
          break
        fi
      done

      if [[ -f "$json_file" ]]; then
        local -a json_keys
        local IFS=$'\n'
        # Finds deep keys (paths) and joins them with dots
        local jq_query='paths(scalars) | map(tostring) | join(".")'

        if [[ "$json_file" == *.jsonl ]]; then
          json_keys=($(head -n 1000 "$json_file" | jq -r "$jq_query" 2>/dev/null | sort -u))
        else
          json_keys=($(jq -r "$jq_query" "$json_file" 2>/dev/null | sort -u))
        fi

        _describe 'keys' json_keys
      else
        _message "Enter a filename first to trigger key completion"
      fi
      ;;
  esac
}
compdef _jview jview
