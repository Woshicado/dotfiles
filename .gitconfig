[core]
  autocrlf = input
  pager = delta --hyperlinks

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true
  light = false
  side-by-side = true
  line-numbers = true

[merge]
  conflictstyle = diff3

[diff]
  colorMoved = default

[user]
  name = Joshua Meyer
  email = s8jjmeye@stud.uni-saarland.de
	signingkey = 67CD220428F9F1A6

[init]
  defaultBranch = main

[alias]
  pullall = "!f(){ git pull \"$@\" && git submodule update --init --recursive; }; f"

[commit]
	gpgsign = true
