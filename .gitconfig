# ~/.gitconfig
[core]
  autocrlf = input
  pager = delta --hyperlinks
  excludesFile = ~/.gitignore-global
  compression = 9
  whitespace = error
  preloadindex = true

[url "git@github.com:woshicado/"]
  insteadOf = "wc:"
[url "git@github.com:"]
  insteadOf = "gh:"
[url "ssh://git@mgit/phd-joshua/"]
  insteadOf = "phd:"
[url "ssh://git@mgit/"]
  insteadOf = "mgit:"

[push]
  autoSetupRemote = true
  default = current
  followTags = true

[pull]
  default = current
  rebase = true

[rebase]
  autoStash = true
  missingCommitsCheck = warn

[advice]
  addEmptyPathspec = false
  statusHints = false

[log]
  abbrevCommit = true
  graphColors = blue,yellow,cyan,magenta,green,red

[color "decorate"]
  HEAD = red
  branch = blue
  rag = yellow
  remoteBranch = magenta

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true
  light = false
  side-by-side = true
  line-numbers = true

[merge]
  conflictstyle = diff3

[diff]
  colorMoved = default

[init]
  defaultBranch = main

[alias]
  pullall = "!f(){ git pull \"$@\" && git submodule update --init --recursive; }; f"

[commit]
  gpgsign = true

[include]
  path = .gitconfig-personal

[includeIf "gitdir:~/Documents/Uni/"]
  path = .gitconfig-uni
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
