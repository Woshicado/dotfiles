# ~/.gitconfig
[core]
  autocrlf = input
  pager = delta --hyperlinks
  excludesfile = /home/woshi/.gitignore-global

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true
  light = false
  side-by-side = true
  line-numbers = true

[merge]
  conflictstyle = diff3

[diff]
  colorMoved = default

[init]
  defaultBranch = main

[alias]
  pullall = "!f(){ git pull \"$@\" && git submodule update --init --recursive; }; f"

[commit]
  gpgsign = true

[include]
  path = .gitconfig-personal

[includeIf "gitdir:~/Documents/Uni/"]
  path = .gitconfig-uni
